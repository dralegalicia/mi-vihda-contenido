import os
import json
import google.generativeai as genai
from datetime import datetime

# Configuración
api_key = os.environ.get("GEMINI_API_KEY")
genai.configure(api_key=api_key)
model = genai.GenerativeModel('gemini-pro')

def get_youtube_thumbnail(url):
    video_id = url.split("v=")[-1]
    return f"https://img.youtube.com/vi/{video_id}/maxresdefault.jpg"

# Generación de Contenido con IA
def generar_bloque(prompt):
    return model.generate_content(prompt).text

# Links de referencia (puedes cambiarlos cuando quieras)
link_receta = "https://www.youtube.com/watch?v=EdhZ2MD-dnE"
link_obesidad = "https://www.youtube.com/watch?v=ZMv3FjYCKbE"

data = {
    "fecha_actualizacion": datetime.now().strftime("%Y-%m-%d"),
    "recursos_obesidad": [{
        "titulo": "Manejando el Peso en VIH",
        "descripcion": generar_bloque("Escribe una descripción corta y empática sobre la importancia del control de peso en pacientes con VIH."),
        "link": link_obesidad,
        "url_imagen": get_youtube_thumbnail(link_obesidad)
    }],
    "noticias": [{
        "titulo": "Avances Médicos Recientes",
        "resumen": generar_bloque("Escribe un resumen breve y esperanzador sobre avances en salud para personas con VIH."),
        "link": "https://news.un.org/es/tags/salud"
    }],
    "consejos": [{
        "titulo": "Consejo de Bienestar",
        "texto": generar_bloque("Escribe un consejo breve y cariñoso de salud o nutrición para alguien que vive con VIH.")
    }],
    "recetas": [{
        "nombre": "Receta Saludable del Día",
        "descripcion": generar_bloque("Describe brevemente una receta saludable, sencilla y nutritiva."),
        "link_externo": link_receta,
        "url_imagen": get_youtube_thumbnail(link_receta)
    }],
    "salud_mental": {
        "emocion_del_dia": "Bienestar",
        "desafio": generar_bloque("Escribe un pequeño desafío de bienestar emocional para hoy."),
        "afirmacion_positiva": generar_bloque("Escribe una afirmación positiva para pacientes con VIH."),
        "puntos_ganados": 50
    }
}

with open("contenido_nutri.json", "w", encoding="utf-8") as f:
    json.dump(data, f, ensure_ascii=False, indent=2)
